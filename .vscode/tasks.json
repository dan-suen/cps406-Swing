{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "javac -d out $(find . -name '*.java')",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run",
      "type": "shell",
      "command": "java -cp out Main",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "dependsOn": "Build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}